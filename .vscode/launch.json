{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Run Discord Bot",
            "program": "${workspaceFolder}/bot.js",
            "envFile": "${workspaceFolder}/.env",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "restart": true,
            "autoAttachChildProcesses": true
        }
    ]
}